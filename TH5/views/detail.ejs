<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title><%= post.title %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h1 style="border-bottom: none; margin-bottom: 5px;"><%= post.title %></h1>
        <p style="color: #9ca3af; font-size: 14px; margin-bottom: 25px;">Đăng lúc: <%= post.createdAt.toLocaleString('vi-VN') %></p>
        
        <div style="background: #f9fafb; padding: 25px; border-radius: 12px; border: 1px solid #f3f4f6;">
            <p style="white-space: pre-wrap; line-height: 1.8; color: #374151; margin: 0; font-size: 16px;"><%= post.body %></p>
        </div>
        
        <div style="margin-top: 30px; display: flex; justify-content: space-between; align-items: center;">
            <a href="/" class="btn-primary" style="background: #6b7280;">← Về danh sách</a>
            <a href="/blogposts/edit/<%= post._id %>" class="btn-primary" style="background: #f59e0b;">Sửa bài này</a>
        </div>
    </div>
</body>
</html>